# Noisebrief — environment variables (example)
#
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# Next.js loads .env.local automatically. Do not commit .env.local to git.

# Supabase — required for storing and serving daily briefs
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API — required for daily summary (Sonnet)
# (LinkedIn / tone post generation — MAKE IT YOURS — disabled)
ANTHROPIC_API_KEY=

# Secures the daily cron endpoint; Vercel Cron sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Resend — digest emails (get API key at resend.com)
RESEND_API_KEY=

# Supabase webhook secret for subscriber notifications
WEBHOOK_SECRET=

# Your email for subscriber notifications
OWNER_EMAIL=

# Upstash Redis — rate limiting (get free credentials at upstash.com/redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Base URL for the site (metadata, sitemap, OG). Phase 10: set to custom domain.
NEXT_PUBLIC_SITE_URL=
